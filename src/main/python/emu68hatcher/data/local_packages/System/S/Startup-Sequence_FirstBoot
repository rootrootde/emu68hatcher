FailAt 21
; PiStorm vs UAE is detected by probing brcm-emmc.device / brcm-sdhc.device.
; $KICKVER is set by the ROM itself.
IF NOT $UAEMAJOR GT 0
   C:Version brcm-emmc.device >NIL:
   IF NOT FAIL
      C:SetEnv System "PiStorm"
      C:SetEnv RpiType "RPi4"
      SYS:C/EMU68INFO variant >ENV:PistormVariant
   ELSE
      C:Version brcm-sdhc.device >NIL:
      IF NOT FAIL
         C:SetEnv System "PiStorm"
         C:SetEnv RpiType "RPi3"
         SYS:C/EMU68INFO variant >ENV:PistormVariant
      ELSE
         C:SetEnv SYSTEM "UAE"
      ENDIF
   ENDIF
ELSE
   C:SetEnv SYSTEM "UAE"
ENDIF
IF $KICKVER EQ 47
   C:SetEnv KickstartVersion 3.2
ELSE
   C:Version Workbench.Library 45 >NIL:
   IF NOT WARN
      C:SetEnv KickstartVersion 3.9
   ELSE
      C:Version exec.library VERSION 40 >NIL:
      IF NOT WARN
         C:SetEnv KickstartVersion 3.1
      ENDIF
   ENDIF
ENDIF

; capture FIRSTTIMEBOOT before the wizard clears it so the wizard body
; can gate on a stable per-boot flag
C:SetEnv HATCHERFIRSTBOOT $FIRSTTIMEBOOT

; Assign EMU68BOOT: to the FAT32 boot partition. the stock DOSDrivers auto-mount
; runs later in the sequence than this point, so mount SD0: explicitly here first.
IF NOT $SYSTEM EQ "UAE"
   C:Assign >NIL: EXISTS SD0:
   IF WARN
      C:Mount >NIL: SD0:
   ENDIF
   C:Assign >NIL: EXISTS SD0:
   IF NOT WARN
      C:Assign >NIL: EMU68BOOT: SD0:
   ENDIF
ELSE
   C:MakeDir >NIL: RAM:EMU68BOOT
   C:Assign >NIL: EMU68BOOT: RAM:EMU68BOOT
ENDIF

; first-boot wizard lives in S:Hatcher-FirstBoot and self-deletes when done
IF EXISTS S:Hatcher-FirstBoot
   C:Execute S:Hatcher-FirstBoot
ENDIF

FailAt 21
