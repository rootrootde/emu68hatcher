FailAt 21
; Hatcher first-boot wizard. dispatched from S:Startup-Sequence after
; BindDrivers. self-deletes after the interactive wizard completes.

IF $FIRSTTIMEBOOT EQ "TRUE"
   C:Echo ""
   C:Echo "============================================"
   C:Echo "   Emu68 Hatcher - First Boot Setup"
   C:Echo "============================================"
   C:Echo ""
   IF $System EQ "PiStorm"
      C:Echo "Detected: PiStorm on $RpiType"
   ELSE
      C:Echo "Detected: UAE emulator"
   ENDIF
   C:Echo ""
ENDIF

; first-time hardware bootstrap - runs S:FirstBoot/* one-shot scripts
IF NOT EXISTS S:FirstBoot.done
   IF $FIRSTTIMEBOOT EQ "TRUE"
      C:Echo "Step 1/4: Configuring hardware..."
   ENDIF
   C:CE >NIL: S:FirstBoot
   IF WARN
      C:Echo >T:RunTimeScript "FailAt 21"
      IF $SYSTEM EQ "UAE"
         C:List >>T:RunTimeScript S:FirstBoot PAT=~(#?.info|#?_pistorm) LFORMAT="C:Echo *"  - %n*"*nC:Execute *"%p%n*"*nC:Delete *"%p%n*"*n" ALL FILES
      ELSE
         C:List >>T:RunTimeScript S:FirstBoot PAT=~(#?.info|) LFORMAT="C:Echo *"  - %n*"*nC:Execute *"%p%n*"*nC:Delete *"%p%n*"*n" ALL FILES
      ENDIF
      C:Execute T:RunTimeScript
      FailAt 21
      C:Delete >NIL: T:RunTimeScript
   ENDIF
   C:Echo >S:FirstBoot.done "TRUE"
   IF $FIRSTTIMEBOOT EQ "TRUE"
      C:Echo ""
   ENDIF
ENDIF

IF $FIRSTTIMEBOOT EQ "TRUE"
   C:Echo "Step 2/4: Setting up display driver..."
   C:Echo ""
ENDIF

; clear FIRSTTIMEBOOT early so a partial wizard run does not repeat
IF $FIRSTTIMEBOOT EQ "TRUE"
   C:Echo "FALSE" > SYS:PREFS/ENV-ARCHIVE/FIRSTTIMEBOOT
ENDIF
IF $REBOOT EQ "TRUE"
   C:Echo "FALSE" > SYS:PREFS/ENV-ARCHIVE/REBOOT
   C:Echo "The Amiga will REBOOT in 3 seconds!"
   C:DiskChange SDH0:
   C:Wait 3
   C:Reboot
ENDIF

IF $HATCHERFIRSTBOOT EQ "TRUE"
   C:Echo "Step 3/4: Mounting boot partition..."
   C:Echo ""

   C:Echo "Step 4/4: Regional settings"
   C:Echo ""

   ; restore cmdline.txt backup (PiStorm only)
   IF NOT $SYSTEM EQ "UAE"
      C:Assign >NIL: EXISTS EMU68BOOT:
      IF NOT WARN
         IF EXISTS EMU68BOOT:cmdlineBAK.txt
            C:Delete EMU68BOOT:cmdline.txt QUIET
            C:Rename FROM EMU68BOOT:cmdlineBAK.txt TO EMU68BOOT:cmdline.txt
         ENDIF
      ENDIF
   ENDIF

   ; Locale + Input preferences
   C:Echo "The Locale and Input preferences will open next."
   C:Echo "Pick your regional and keymap/mouse settings, then Save each."
   C:Echo ""
   C:Ask "Press RETURN to continue..."
   IF $KickstartVersion EQ 3.9
      C:AddDataTypes REFRESH QUIET
   ENDIF
   SYS:Prefs/Locale
   SYS:Prefs/Input

   ; re-enable disabled WBStartup items
   IF EXISTS SYS:WBStartup/Disabled
      C:Copy >NIL: "SYS:WBStartup/Disabled/#?" TO "SYS:WBStartup/" ALL FORCE CLONE
      C:Delete >NIL: "SYS:WBStartup/Disabled" ALL FORCE
   ENDIF

   ; this script has done its job
   C:Delete >NIL: S:Hatcher-FirstBoot QUIET

   C:Echo ""
   C:Echo "Setup will now reboot to apply changes."
   C:Echo "One more brief setup step after reboot (display settings)."
   C:Echo ""
   C:Ask "Press RETURN to reboot..."
   C:DiskChange SDH0:
   IF $System EQ "UAE"
      C:Reboot
   ELSE
      C:EMU68INFO HARDRESET
   ENDIF
ENDIF

FailAt 21
