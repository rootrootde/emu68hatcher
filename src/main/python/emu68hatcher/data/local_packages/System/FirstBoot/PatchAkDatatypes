; apply 68040 CPU-optimized patches to akDT image datatypes

C:Echo "Patching akDatatypes for 68040..."

; akPNG
IF EXISTS SYS:Classes/DataTypes/akPNG-040.pch
   IF EXISTS SYS:Classes/DataTypes/akPNG.datatype
      C:spatch >NIL: -oSYS:Classes/DataTypes/akPNG.datatype.new -pSYS:Classes/DataTypes/akPNG-040.pch SYS:Classes/DataTypes/akPNG.datatype
      IF EXISTS SYS:Classes/DataTypes/akPNG.datatype.new
         C:Delete >NIL: SYS:Classes/DataTypes/akPNG.datatype
         C:Rename >NIL: SYS:Classes/DataTypes/akPNG.datatype.new SYS:Classes/DataTypes/akPNG.datatype
      ENDIF
   ENDIF
   C:Delete >NIL: SYS:Classes/DataTypes/akPNG-040.pch
ENDIF

