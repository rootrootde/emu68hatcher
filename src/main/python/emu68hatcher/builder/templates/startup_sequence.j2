; Startup-Sequence
; Generated by Emu68 Hatcher
;

FailAt 21

; Ensure C: is assigned (needed for commands)
SYS:C/Assign >NIL: C: SYS:C

C:SetPatch QUIET
C:BindDrivers

C:Mount >NIL: DEVS:DOSDrivers/~(#?.info)

; Set up assigns
C:Assign >NIL: ENVARC: SYS:Prefs/Env-Archive
C:Assign >NIL: WORK: {{ config.work_device }}:
C:Assign >NIL: LOCALE: SYS:
C:Assign >NIL: KEYMAPS: DEVS:Keymaps

; Create RAM directories first, then assign
C:MakeDir RAM:ENV RAM:T >NIL:
C:Assign ENV: RAM:ENV
C:Assign T: RAM:T

; Copy saved preferences to ENV:
C:Copy >NIL: ENVARC: ENV: ALL QUIET

{% if config.has_picasso96 %}
; - Picasso96 RTG (apply preferences) -
IF EXISTS LIBS:Picasso96API.library
  C:AddDataTypes REFRESH QUIET
  C:IPrefs
ENDIF

{% endif %}
C:Resident >NIL: C:Assign PURE
C:Resident >NIL: C:Execute PURE

C:Path RAM: C: SYS:Utilities SYS:Rexxc SYS:System S: SYS:Prefs SYS:Tools SYS:Tools/Commodities ADD

FailAt 21
If EXISTS SYS:System/RexxMast
  SYS:System/RexxMast >NIL:
EndIf
FailAt 10

; Detect system type (UAE vs PiStorm)
SYS:C/SysVars
IF NOT $UAEMAJOR GT 0
  C:Version brcm-emmc.device >NIL:
  IF NOT FAIL
    C:SetEnv System "PiStorm"
    C:SetEnv RpiType "RPi4"
  ELSE
    C:Version brcm-sdhc.device >NIL:
    IF NOT FAIL
      C:SetEnv System "PiStorm"
      C:SetEnv RpiType "RPi3"
    ELSE
      C:SetEnv SYSTEM "UAE"
    ENDIF
  ENDIF
ELSE
  C:SetEnv SYSTEM "UAE"
ENDIF

; OneTimeRun - first boot scripts
IF EXISTS S:OneTimeRun
  C:Echo "Running first-boot scripts..."
  FailAt 30
  C:Echo >T:RunTimeScript "FailAt 21"
  IF $SYSTEM EQ "UAE"
    C:List >>T:RunTimeScript S:OneTimeRun PAT=~(#?.info|#?_pistorm) LFORMAT="C:Echo *\"Running Script: %n*\"*nC:Echo *\"*\"*nC:Execute *\"%p%n*\"*nC:Delete *\"%p%n*\"*n" ALL FILES
  ELSE
    C:List >>T:RunTimeScript S:OneTimeRun PAT=~(#?.info|) LFORMAT="C:Echo *\"Running Script: %n*\"*nC:Echo *\"*\"*nC:Execute *\"%p%n*\"*nC:Delete *\"%p%n*\"*n" ALL FILES
  ENDIF
  C:Execute T:RunTimeScript
  C:Delete >NIL: T:RunTimeScript
  FailAt 10
ENDIF

; Assign EMU68BOOT: volume
IF NOT $SYSTEM EQ "UAE"
  IF EXISTS SD0:
    C:Assign >NIL: EMU68BOOT: SD0:
  ENDIF
ELSE
  ; In UAE mode, create dummy assign to avoid "Please insert volume" requesters
  C:MakeDir >NIL: RAM:EMU68BOOT
  C:Assign >NIL: EMU68BOOT: RAM:EMU68BOOT
ENDIF

; Raise FailAt for startup scripts (assigns may return 20 if paths don't exist)
FailAt 21

If EXISTS S:User-Startup
  C:Execute S:User-Startup
EndIf

; OneTimeRunWB - workbench-level first boot tasks
IF EXISTS S:OneTimeRunWB.script
  C:Execute S:OneTimeRunWB.script
ENDIF

C:LoadWB

C:EndCLI >NIL:
